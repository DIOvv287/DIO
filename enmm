-- ==========================================
-- 独立 ESP 透视脚本 (Standalone Version)
-- 功能：玩家方框、名字、血量、距离显示
-- ==========================================

-- 安全获取服务
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- 配置区
local ESPConfig = {
    Enabled = false,
    TeamCheck = true,
    BoxColor = Color3.fromRGB(0, 255, 0),
    NameColor = Color3.fromRGB(255, 255, 255),
    HealthColor = Color3.fromRGB(0, 255, 0),
    DistanceColor = Color3.fromRGB(200, 200, 200),
    Keybind = Enum.KeyCode.RightAlt
}

-- 存储所有绘制对象
local Drawings = {}

-- 清空所有ESP绘制
local function ClearESP()
    for _, obj in pairs(Drawings) do
        obj:Remove()
    end
    table.clear(Drawings)
end

-- 更新ESP
local function UpdateESP()
    ClearESP()
    
    if not ESPConfig.Enabled then
        return
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            -- 队友过滤
            if ESPConfig.TeamCheck and player.Team == LocalPlayer.Team then
                continue
            end

            local character = player.Character
            if not character then continue end

            local humanoid = character:FindFirstChild("Humanoid")
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            if not humanoid or not rootPart or humanoid.Health <= 0 then
                continue
            end

            -- 世界坐标转屏幕坐标
            local pos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
            if not onScreen then continue end

            -- 计算方框大小（根据距离缩放）
            local distance = math.floor((rootPart.Position - Camera.CFrame.Position).Magnitude)
            local boxSize = Vector2.new(3000 / pos.Z, 4000 / pos.Z)
            local boxPos = Vector2.new(pos.X - boxSize.X / 2, pos.Y - boxSize.Y / 2)

            -- 1. 绘制方框
            local box = Drawing.new("Square")
            box.Visible = true
            box.Transparency = 1
            box.Color = ESPConfig.BoxColor
            box.Thickness = 1.5
            box.Filled = false
            box.Size = boxSize
            box.Position = boxPos
            table.insert(Drawings, box)

            -- 2. 绘制玩家名字
            local name = Drawing.new("Text")
            name.Visible = true
            name.Text = player.Name
            name.Color = ESPConfig.NameColor
            name.Size = 16
            name.Center = true
            name.Position = Vector2.new(pos.X, boxPos.Y - 20)
            table.insert(Drawings, name)

            -- 3. 绘制血量
            local healthText = Drawing.new("Text")
            healthText.Visible = true
            healthText.Text = string.format("HP: %d", math.floor(humanoid.Health))
            healthText.Color = ESPConfig.HealthColor
            healthText.Size = 14
            healthText.Center = true
            healthText.Position = Vector2.new(pos.X, boxPos.Y + boxSize.Y + 5)
            table.insert(Drawings, healthText)

            -- 4. 绘制距离
            local distanceText = Drawing.new("Text")
            distanceText.Visible = true
            distanceText.Text = tostring(distance) .. "m"
            distanceText.Color = ESPConfig.DistanceColor
            distanceText.Size = 14
            distanceText.Center = true
            distanceText.Position = Vector2.new(pos.X, boxPos.Y + boxSize.Y + 22)
            table.insert(Drawings, distanceText)
        end
    end
end

-- 绑定渲染更新
RunService.RenderStepped:Connect(UpdateESP)

-- 快捷键开关
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == ESPConfig.Keybind then
        ESPConfig.Enabled = not ESPConfig.Enabled
        warn("ESP " .. (ESPConfig.Enabled and "已启用" or "已禁用"))
    end
end)

-- 可选：添加一个简单UI开关（基于之前的迪亚哥主题）
local function CreateUI()
    local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
    if PlayerGui:FindFirstChild("ESP_UI") then
        PlayerGui:FindFirstChild("ESP_UI"):Destroy()
    end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "ESP_UI"
    ScreenGui.Parent = PlayerGui
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.IgnoreGuiInset = true

    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0, 180, 0, 100)
    MainFrame.Position = UDim2.new(0.02, 0, 0.02, 0)
    MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 25)
    MainFrame.BorderSizePixel = 2
    MainFrame.BorderColor3 = Color3.fromRGB(0, 180, 255)
    MainFrame.Active = true
    MainFrame.Draggable = true
    MainFrame.Parent = ScreenGui

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, 0, 0, 30)
    Title.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    Title.Text = "「恐竜の視界」ESP"
    Title.TextColor3 = Color3.new(0, 0, 0)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 14
    Title.Parent = MainFrame

    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Size = UDim2.new(0, 140, 0, 30)
    ToggleBtn.Position = UDim2.new(0.5, -70, 0.5, -15)
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
    ToggleBtn.Text = "启用 ESP"
    ToggleBtn.TextColor3 = Color3.new(1, 1, 1)
    ToggleBtn.Font = Enum.Font.Gotham
    ToggleBtn.TextSize = 14
    ToggleBtn.Parent = MainFrame

    ToggleBtn.MouseButton1Click:Connect(function()
        ESPConfig.Enabled = not ESPConfig.Enabled
        ToggleBtn.Text = ESPConfig.Enabled and "禁用 ESP" or "启用 ESP"
        ToggleBtn.BackgroundColor3 = ESPConfig.Enabled and Color3.fromRGB(255, 0, 60) or Color3.fromRGB(0, 180, 255)
    end)
end

-- 启动UI
CreateUI()

warn("=====================================")
warn("   ESP 脚本加载完成！")
warn("   快捷键: RightAlt 开关ESP")
warn("=====================================")
