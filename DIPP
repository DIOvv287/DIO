local function createDioButton(parent, name, callback)
    local button = Instance.new("TextButton")
    button.Name = "DioButton_" .. name
    button.Parent = parent
    button.BackgroundColor3 = DIO_UI_CONFIG.MainColor
    button.BorderColor3 = DIO_UI_CONFIG.BorderColor
    button.BorderSizePixel = 1
    button.Size = UDim2.new(0.45, 0, 0.35, 0)
    button.Font = DIO_UI_CONFIG.Font
    button.Text = name
    button.TextColor3 = DIO_UI_CONFIG.TextColor
    button.TextSize = 12
    
    button.MouseEnter:Connect(function()
        button.BackgroundColor3 = DIO_UI_CONFIG.ButtonHoverColor
    end)
    button.MouseLeave:Connect(function()
        button.BackgroundColor3 = DIO_UI_CONFIG.MainColor
    end)
    button.MouseButton1Click:Connect(callback)
    
    return button
end

local function createDioToggle(parent, name, default, callback)
    local toggle = Instance.new("TextButton")
    toggle.Name = "DioToggle_" .. name
    toggle.Parent = parent
    toggle.BackgroundColor3 = default and DIO_UI_CONFIG.SecondaryColor or DIO_UI_CONFIG.MainColor
    toggle.BorderColor3 = DIO_UI_CONFIG.BorderColor
    toggle.BorderSizePixel = 1
    toggle.Size = UDim2.new(0.45, 0, 0.35, 0)
    toggle.Font = DIO_UI_CONFIG.Font
    toggle.Text = name .. (default and " [开启]" or " [关闭]")
    toggle.TextColor3 = DIO_UI_CONFIG.TextColor
    toggle.TextSize = 12
    local isEnabled = default
    
    toggle.MouseEnter:Connect(function()
        toggle.BackgroundColor3 = isEnabled and Color3.fromRGB(255, 230, 0) or DIO_UI_CONFIG.ButtonHoverColor
    end)
    toggle.MouseLeave:Connect(function()
        toggle.BackgroundColor3 = isEnabled and DIO_UI_CONFIG.SecondaryColor or DIO_UI_CONFIG.MainColor
    end)
    toggle.MouseButton1Click:Connect(function()
        isEnabled = not isEnabled
        toggle.Text = name .. (isEnabled and " [开启]" or " [关闭]")
        toggle.BackgroundColor3 = isEnabled and DIO_UI_CONFIG.SecondaryColor or DIO_UI_CONFIG.MainColor
        callback(isEnabled)
    end)
    
    return toggle
end

